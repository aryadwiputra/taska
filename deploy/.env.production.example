APP_NAME=Taska
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://taska.web.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=taska
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.taska.web.id

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@taska.web.id"
MAIL_FROM_NAME="${APP_NAME}"

MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

VITE_APP_NAME="${APP_NAME}"

WHATSAPP_GATEWAY_URL=http://127.0.0.1:3001
WHATSAPP_API_TOKEN=

REALTIME_GATEWAY_URL=http://127.0.0.1:3002
REALTIME_API_TOKEN=
LARAVEL_API_TOKEN=

VITE_SOCKETIO_URL=https://taska.web.id
